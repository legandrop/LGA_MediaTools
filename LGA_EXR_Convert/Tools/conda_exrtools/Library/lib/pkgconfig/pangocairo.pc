prefix=C:/Portable/LGA_MediaTools/LGA_EXR_Convert/Tools/conda_exrtools/Library
includedir=${prefix}/include
libdir=${prefix}/lib

Name: Pango Cairo
Description: Cairo rendering support for Pango
Version: 1.56.4
Requires: pango, cairo >=  1.18.0
Requires.private: pangoft2, pangowin32, glib-2.0 >=  2.82, gobject-2.0 >=  2.82, gio-2.0 >=  2.82, fribidi >=  1.0.6, harfbuzz >=  8.4.0, fontconfig >=  2.15.0, freetype2, harfbuzz-gobject >=  8.4.0
Libs: -L${libdir} -lpangocairo-1.0
Libs.private: -lgdi32
Cflags: -I${includedir}/pango-1.0
